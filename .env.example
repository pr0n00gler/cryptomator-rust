# S3 Configuration Example
# Copy this file to .env and fill in your values

# Required
S3_BUCKET=test
S3_REGION=us-east-1

# Optional
S3_PREFIX=test/vault/
S3_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=true
S3_VALIDATE_BUCKET=false
S3_ACCESS_KEY=test
S3_SECRET_KEY=test
S3_SESSION_TOKEN=
S3_REQUEST_TIMEOUT_SECONDS=30
